# Supabase configuration for Liveshare feature
# Copy this file to .env and replace with your actual Supabase credentials

# Your Supabase project URL
REACT_APP_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (safe to expose in client-side code)
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Features enabled with Supabase:
# - Real-time combat state sharing
# - Session expiration controls  
# - Manual session deactivation

# Security Note: Supabase anon keys are designed to be public-facing
# They only provide limited access based on Row Level Security (RLS) policies
# Never commit your actual .env file to version control

# AWS Cards API (from CDK output: HttpApiUrl)
REACT_APP_CARDS_API_URL=https://xxxxxx.execute-api.us-east-1.amazonaws.com

# Admin Cognito auth (from CDK outputs after `cdk deploy`)
REACT_APP_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_AWS_REGION=us-east-1
